# Copy this file to .env and fill in your API keys
# Never commit .env to version control

# ── Model API Keys ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── Evaluation Settings ───────────────────────────────────────────────────────
# Max tokens for model responses
CSB_MAX_TOKENS=1024

# Temperature (0.0 = deterministic, recommended for eval)
CSB_TEMPERATURE=0.0

# Request delay in seconds between API calls (avoid rate limits)
CSB_REQUEST_DELAY=0.5

# Results output directory
CSB_RESULTS_DIR=results

# ── Logging ───────────────────────────────────────────────────────────────────
CSB_LOG_LEVEL=INFO
